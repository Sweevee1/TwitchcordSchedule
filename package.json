{
  "name": "twitchcord-schedule",
  "version": "1.0.0",
  "description": "Syncs Twitch channel schedule to Discord Guild Scheduled Events",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "postbuild": "xcopy /E /I /Y src\\web\\public dist\\web\\public 2>nul || cp -r src/web/public dist/web/public",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts"
  },
  "dependencies": {
    "@twurple/api": "^7.0.0",
    "@twurple/auth": "^7.0.0",
    "discord.js": "^14.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "node-cron": "^3.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
